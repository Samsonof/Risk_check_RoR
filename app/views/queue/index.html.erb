<% content_for :title, "Review queue" %>

<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
  <div>
    <p class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Workspace</p>
    <h1 class="text-2xl font-semibold text-slate-900">Manual review queue</h1>
    <p class="mt-1 text-sm text-slate-500">Cases the engine sent to humans. Sorted by priority, then by time-in-queue.</p>
  </div>
  <div class="grid grid-cols-3 gap-3 text-center">
    <div class="rounded-lg border border-slate-200 bg-white px-4 py-2">
      <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">In queue</p>
      <p class="text-xl font-semibold text-slate-900"><%= @in_queue.size %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white px-4 py-2">
      <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Auto-approved</p>
      <p class="text-xl font-semibold text-emerald-600"><%= @auto_approved_count %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white px-4 py-2">
      <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Resolved</p>
      <p class="text-xl font-semibold text-slate-600"><%= @resolved_count %></p>
    </div>
  </div>
</div>

<% if @in_queue.empty? %>
  <div class="rounded-xl border border-slate-200 bg-white p-8 text-center text-sm text-slate-500">
    Queue is empty. Either all cases are auto-approved or operators handled them all.
  </div>
<% else %>
  <ul class="space-y-3">
    <% @in_queue.each do |wr| %>
      <% decision = wr.latest_decision %>
      <% priority = effective_priority(wr) %>
      <% client = wr.client %>
      <li>
        <%= link_to case_path(wr), class: "block rounded-xl border border-slate-200 bg-white shadow-sm hover:shadow-md transition-shadow border-l-4 #{priority_border(priority)}" do %>
          <div class="grid grid-cols-12 gap-4 p-4">
            <div class="col-span-12 md:col-span-3 flex flex-col gap-2">
              <span class="inline-flex w-fit items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-semibold tracking-wide <%= priority_chip(priority) %>">
                <%= priority_label(priority) %>
              </span>
              <p class="text-sm font-medium text-slate-900"><%= wr.request_id %> · <%= client.external_id %></p>
              <p class="text-xs text-slate-500"><%= client.name %> · <%= client.country_code %> · KYC T<%= client.kyc_tier %></p>
            </div>

            <div class="col-span-6 md:col-span-2">
              <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Amount</p>
              <p class="text-base font-semibold text-slate-900"><%= money(wr.amount_usd) %></p>
              <p class="text-xs text-slate-500"><%= method_icon(wr.method) %> <%= wr.method %></p>
            </div>

            <div class="col-span-6 md:col-span-2">
              <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Score</p>
              <p class="text-base font-semibold text-slate-900"><%= decision&.score_pts || 0 %> pts</p>
              <p class="text-xs text-slate-500">target SLA <%= priority_sla(priority) %></p>
            </div>

            <div class="col-span-6 md:col-span-3">
              <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Reasons</p>
              <p class="text-xs text-slate-700 leading-snug">
                <% decision&.reasons&.first(3)&.each do |r| %>
                  <span class="inline-block rounded bg-slate-100 px-1.5 py-0.5 mr-1 mb-0.5 text-[11px]"><%= r["message"] %></span>
                <% end %>
                <% if (decision&.reasons || []).size > 3 %>
                  <span class="text-[11px] text-slate-500">+<%= decision.reasons.size - 3 %> more</span>
                <% end %>
              </p>
            </div>

            <div class="col-span-6 md:col-span-2 text-right">
              <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">In queue</p>
              <p class="text-base font-semibold text-slate-900"><%= time_in_queue_label(wr.time_in_queue_hours) %></p>
              <p class="text-[11px] text-indigo-600 hover:underline">Open →</p>
            </div>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>
